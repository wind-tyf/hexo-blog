{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "hexo generate",
  "outputDirectory": "public",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)\\.(js|css|woff2|woff|ttf|otf|svg|png|jpg|jpeg|gif|ico|webp)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/atom.xml",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=600, s-maxage=3600" },
        { "key": "Content-Type", "value": "application/atom+xml; charset=utf-8" }
      ]
    }
  ]
}
